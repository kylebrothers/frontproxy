# Copy this file to .env and set values for your environment.
# .env is gitignored and never committed.

# IP address of the rm-sync host on the LAN
RMSYNC_IP=192.168.0.154

# Ports on the rm-sync host (defaults match standard HTTP/HTTPS)
RMSYNC_HTTP_PORT=80
RMSYNC_HTTPS_PORT=443

# Port that the MediaWiki container listens on on this host's loopback
MEDIAWIKI_PORT=8080
